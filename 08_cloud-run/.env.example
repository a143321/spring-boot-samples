# ── Google Cloud 設定 ──────────────────────────────────
PROJECT_ID=elegant-karma-492109-n2
REGION=asia-northeast1
SERVICE_NAME=factory-app
REPO=factory

# ── Supabase 接続情報（Transaction pooler 経由・IPv4対応） ──
# Supabase ダッシュボード → Connect → Direct → Transaction pooler → JDBC
# ポートは 6543（Direct の 5432 とは異なる）
DB_URL=jdbc:postgresql://aws-1-ap-northeast-1.pooler.supabase.com:6543/postgres
DB_USER=postgres.[your-project-ref]
DB_PASS=your-supabase-password
